---
import { stack } from '@data/stack';
import { type Lang } from '@i18n/ui';
import { useTranslations } from '@i18n/utils';

interface Props { lang?: Lang; }
const { lang = 'es' } = Astro.props;
const t = useTranslations(lang);

// Category SVG icons (inline, no CDN)
const icons: Record<string, string> = {
  backend: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <rect x="2" y="3" width="20" height="5" rx="2"/>
    <rect x="2" y="10" width="20" height="5" rx="2"/>
    <rect x="2" y="17" width="20" height="5" rx="2"/>
    <circle cx="6" cy="5.5" r="1" fill="currentColor" stroke="none"/>
    <circle cx="6" cy="12.5" r="1" fill="currentColor" stroke="none"/>
    <circle cx="6" cy="19.5" r="1" fill="currentColor" stroke="none"/>
  </svg>`,
  frontend: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <polyline points="16 18 22 12 16 6"/>
    <polyline points="8 6 2 12 8 18"/>
  </svg>`,
  database: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <ellipse cx="12" cy="5" rx="9" ry="3"/>
    <path d="M3 5v4c0 1.66 4.03 3 9 3s9-1.34 9-3V5"/>
    <path d="M3 9v4c0 1.66 4.03 3 9 3s9-1.34 9-3V9"/>
    <path d="M3 13v4c0 1.66 4.03 3 9 3s9-1.34 9-3v-4"/>
  </svg>`,
  tools: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/>
  </svg>`,
};
---

<section id="stack" class="stack-section">
  <div class="container">
    <div class="section-header" data-reveal>
      <span class="section-label">{t('stack.label')}</span>
      <h2 class="section-title">{t('stack.title')}</h2>
      <p class="section-subtitle">{t('stack.subtitle')}</p>
    </div>

    <div class="stack-grid">
      {
        stack.map((category, i) => (
          <article
            class="stack-card"
            data-reveal
            style={`--delay: ${i * 80}ms`}
          >
            <div class="card-header">
              <span class="card-icon" set:html={icons[category.icon]} />
              <div>
                <h3 class="card-title">{t(`stack.${category.id}.title` as any)}</h3>
                <p class="card-desc">{t(`stack.${category.id}.desc` as any)}</p>
              </div>
            </div>

            <ul class="tech-list" aria-label={`${t('stack.label')}: ${t(`stack.${category.id}.title` as any)}`}>
              {category.techs.map((tech) => (
                <li>
                  <span class={`tech-chip ${tech.level === 'primary' ? 'chip-primary' : 'chip-secondary'}`}>
                    {tech.name}
                  </span>
                </li>
              ))}
            </ul>
          </article>
        ))
      }
    </div>
  </div>
</section>

<script>
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          const el = entry.target as HTMLElement;
          const delay = el.style.getPropertyValue('--delay') || '0ms';
          setTimeout(() => el.classList.add('visible'), parseInt(delay));
          observer.unobserve(el);
        }
      });
    },
    { threshold: 0.1 }
  );

  document.querySelectorAll('[data-reveal]').forEach((el) => observer.observe(el));
</script>

<style>
  .stack-section {
    padding-block: var(--section-padding);
  }

  /* Section header */
  .section-header {
    text-align: center;
    margin-bottom: 3.5rem;
  }

  .section-label {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: 0.75rem;
  }

  .section-title {
    font-family: var(--font-display);
    font-size: clamp(1.8rem, 4vw, 2.8rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    color: var(--color-text);
    margin-bottom: 0.75rem;
  }

  .section-subtitle {
    font-size: 1rem;
    color: var(--color-text-muted);
    max-width: 48ch;
    margin-inline: auto;
    line-height: 1.6;
  }

  /* Grid */
  .stack-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.25rem;
  }

  /* Card */
  .stack-card {
    background: var(--color-bg-elevated);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    padding: 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    transition:
      border-color 250ms ease,
      box-shadow 250ms ease,
      transform 250ms ease;
    cursor: default;
  }

  .stack-card:hover {
    border-color: var(--color-border-accent);
    box-shadow: 0 0 28px rgba(163, 230, 53, 0.08), var(--shadow-card);
    transform: translateY(-3px);
  }

  /* Scroll-reveal */
  [data-reveal] {
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.5s ease, transform 0.5s ease;
  }

  [data-reveal].visible {
    opacity: 1;
    transform: translateY(0);
  }

  @media (prefers-reduced-motion: reduce) {
    [data-reveal] {
      opacity: 1;
      transform: none;
      transition: none;
    }
  }

  /* Card header */
  .card-header {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
  }

  .card-icon {
    flex-shrink: 0;
    width: 42px;
    height: 42px;
    background: rgba(163, 230, 53, 0.08);
    border: 1px solid rgba(163, 230, 53, 0.2);
    border-radius: var(--radius-md);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-accent);
  }

  .card-title {
    font-family: var(--font-display);
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--color-text);
    letter-spacing: -0.01em;
    margin-bottom: 0.2rem;
  }

  .card-desc {
    font-size: 0.8rem;
    color: var(--color-text-muted);
    line-height: 1.5;
  }

  /* Tech chips */
  .tech-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    list-style: none;
  }

  .tech-chip {
    display: inline-block;
    padding: 0.25rem 0.65rem;
    border-radius: var(--radius-sm);
    font-size: 0.78rem;
    font-weight: 500;
    line-height: 1.4;
  }

  .chip-primary {
    background: rgba(163, 230, 53, 0.1);
    color: var(--color-accent);
    border: 1px solid rgba(163, 230, 53, 0.25);
  }

  .chip-secondary {
    background: var(--color-bg-card);
    color: var(--color-text-muted);
    border: 1px solid var(--color-border);
  }

  /* Responsive */
  @media (max-width: 768px) {
    .stack-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
