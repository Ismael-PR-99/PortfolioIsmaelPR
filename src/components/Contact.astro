---
import { SOCIALS } from '@config/site';

const socialLinks = [
  {
    href: SOCIALS.linkedin,
    label: 'LinkedIn',
    description: 'Perfil profesional',
    color: '#0A66C2',
    icon: `<svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>`,
  },
  {
    href: SOCIALS.github,
    label: 'GitHub',
    description: 'Código y proyectos',
    color: '#f4f4f5',
    icon: `<svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/></svg>`,
  },
  {
    href: SOCIALS.instagram,
    label: 'Instagram',
    description: 'Día a día',
    color: '#E1306C',
    icon: `<svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 1 0 0 12.324 6.162 6.162 0 0 0 0-12.324zM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.406-11.845a1.44 1.44 0 1 0 0 2.881 1.44 1.44 0 0 0 0-2.881z"/></svg>`,
  },
] as const;
---

<section id="contact" class="contact-section">
  <div class="container">
    <div class="contact-inner" data-reveal>
      <!-- Header -->
      <div class="contact-header">
        <span class="section-label">Contacto</span>
        <h2 class="contact-title">Conectemos</h2>
        <p class="contact-subtitle">
          Estoy abierto a oportunidades de prácticas y puestos junior.<br />
          Si tienes un proyecto o una oferta, hablemos.
        </p>
      </div>

      <!-- Social buttons -->
      <div class="social-grid" role="list" aria-label="Redes sociales">
        {
          socialLinks.map((link) => (
            <a
              href={link.href}
              target="_blank"
              rel="noopener noreferrer"
              class="social-btn"
              style={`--brand: ${link.color}`}
              role="listitem"
              aria-label={`${link.label} — ${link.description}`}
            >
              <span class="social-icon" set:html={link.icon} />
              <span class="social-info">
                <span class="social-name">{link.label}</span>
                <span class="social-desc">{link.description}</span>
              </span>
              <svg class="social-arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path d="M7 17 17 7M17 7H7M17 7v10"/>
              </svg>
            </a>
          ))
        }
      </div>

      <!-- CV download -->
      <div class="cv-wrap">
        <div class="cv-divider" aria-hidden="true">
          <span>o descarga mi CV</span>
        </div>
        <a
          href={SOCIALS.cv}
          target="_blank"
          rel="noopener noreferrer"
          class="cv-btn"
          aria-label="Descargar CV en PDF (abre en nueva pestaña)"
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
            <polyline points="14 2 14 8 20 8"/>
            <line x1="12" y1="18" x2="12" y2="12"/>
            <line x1="9" y1="15" x2="15" y2="15"/>
          </svg>
          Descargar CV — PDF
        </a>
      </div>
    </div>
  </div>
</section>

<script>
  const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (!prefersReduced) {
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('visible');
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.15 }
    );
    document.querySelectorAll('#contact [data-reveal]').forEach((el) => observer.observe(el));
  } else {
    document.querySelectorAll('#contact [data-reveal]').forEach((el) => el.classList.add('visible'));
  }
</script>

<style>
  .contact-section {
    padding-block: var(--section-padding);
  }

  .contact-inner {
    max-width: 680px;
    margin-inline: auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 3rem;
    text-align: center;
  }

  /* Reveal */
  [data-reveal] {
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.55s ease, transform 0.55s ease;
  }

  [data-reveal].visible {
    opacity: 1;
    transform: translateY(0);
  }

  @media (prefers-reduced-motion: reduce) {
    [data-reveal] { opacity: 1; transform: none; transition: none; }
  }

  /* Header */
  .section-label {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: 0.75rem;
  }

  .contact-header {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0;
  }

  .contact-title {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 6vw, 4rem);
    font-weight: 800;
    letter-spacing: -0.04em;
    color: var(--color-text);
    line-height: 1;
    margin-bottom: 1rem;
  }

  .contact-subtitle {
    font-size: 1rem;
    color: var(--color-text-muted);
    line-height: 1.7;
    max-width: 44ch;
  }

  /* Social grid */
  .social-grid {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    width: 100%;
  }

  .social-btn {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1rem 1.25rem;
    background: var(--color-bg-elevated);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    text-decoration: none;
    transition: border-color 200ms ease, background 200ms ease, transform 200ms ease, box-shadow 200ms ease;
    text-align: left;
  }

  .social-btn:hover {
    border-color: var(--brand);
    background: color-mix(in srgb, var(--brand) 6%, var(--color-bg-elevated));
    transform: translateX(4px);
    box-shadow: -4px 0 0 0 var(--brand), var(--shadow-card);
  }

  .social-icon {
    flex-shrink: 0;
    width: 44px;
    height: 44px;
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--brand);
    transition: border-color 200ms ease;
  }

  .social-icon svg {
    width: 20px;
    height: 20px;
  }

  .social-btn:hover .social-icon {
    border-color: var(--brand);
  }

  .social-info {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
  }

  .social-name {
    font-family: var(--font-display);
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--color-text);
  }

  .social-desc {
    font-size: 0.8rem;
    color: var(--color-text-muted);
  }

  .social-arrow {
    color: var(--color-text-muted);
    flex-shrink: 0;
    transition: color 200ms ease, transform 200ms ease;
  }

  .social-btn:hover .social-arrow {
    color: var(--brand);
    transform: translate(2px, -2px);
  }

  /* CV section */
  .cv-wrap {
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
  }

  .cv-divider {
    display: flex;
    align-items: center;
    gap: 1rem;
    width: 100%;
    color: var(--color-text-muted);
    font-size: 0.8rem;
  }

  .cv-divider::before,
  .cv-divider::after {
    content: '';
    flex: 1;
    height: 1px;
    background: var(--color-border);
  }

  .cv-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.9rem 2rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    background: transparent;
    color: var(--color-text);
    font-size: 0.9rem;
    font-weight: 600;
    text-decoration: none;
    transition: border-color 200ms ease, color 200ms ease, box-shadow 200ms ease, transform 200ms ease;
  }

  .cv-btn:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
    box-shadow: 0 0 16px rgba(163, 230, 53, 0.12);
    transform: translateY(-2px);
  }
</style>
