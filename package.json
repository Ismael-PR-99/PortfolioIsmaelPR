{
  "name": "portfolio-ismael-pr",
  "version": "1.0.0",
  "type": "module",
  "description": "Portfolio personal de Ismael Piña Ramos con TypeScript (fuente en src)",
  "main": "dist/scripts.js",
  "scripts": {
    "dev": "vite",
    "optimize-images": "node scripts/optimize-images.mjs",
    "build": "node scripts/optimize-images.mjs && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write src/",
    "clean": "rimraf dist"
  },
  "keywords": [
    "portfolio",
    "typescript",
    "web-development",
    "frontend"
  ],
  "author": "Ismael Piña Ramos",
  "license": "MIT",
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.59.4",
    "@typescript-eslint/parser": "^8.59.4",
    "eslint": "^10.4.0",
    "eslint-plugin-no-unsanitized": "^4.1.5",
    "prettier": "^3.8.3",
    "rimraf": "^5.0.0",
    "sharp": "^0.34.5",
    "typescript": "^5.3.0",
    "vite": "^5.2.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
